# Configuration locale Twilio.
# Ne pas partager ce fichier : TWILIO_AUTH_TOKEN est un secret.

# Mode recommande pour WhatsApp / Instagram manuel : pas d envoi SMS reel.
SMS_PROVIDER=console
TWILIO_ACCOUNT_SID=AC1372fac72de9257c368160c76b0a0ee6

# A completer depuis la console Twilio.
TWILIO_AUTH_TOKEN=

# Numero Twilio expediteur, pas le numero de la cliente.
# Exemple : +1234567890
TWILIO_FROM=

# Numero destinataire verifie dans Twilio pour les tests.
# Le backend utilise les numeros saisis sur les fiches clients.
TWILIO_TEST_TO=+33621534939
